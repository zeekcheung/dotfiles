{
  "$help": "https://aka.ms/terminal-documentation",
  "$schema": "https://aka.ms/terminal-profiles-schema",
  "actions": [
    {
      "command": "closePane",
      "id": "User.closePane"
    }
  ],
  "alwaysShowNotificationIcon": false,
  "centerOnLaunch": true,
  "copyFormatting": "none",
  "copyOnSelect": true,
  "defaultInputScope": "alphanumericHalfWidth",
  "defaultProfile": "{a3aaaed6-23aa-4124-b1c8-18c7640779f0}",
  "disableAnimations": true,
  "disabledProfileSources": [
    "Windows.Terminal.Azure",
    "Windows.Terminal.VisualStudio"
  ],
  "initialCols": 80,
  "initialPosition": ",",
  "initialRows": 20,
  "keybindings": [
    {
      "id": "Terminal.DuplicatePaneDown",
      "keys": "ctrl+\\"
    },
    {
      "id": "Terminal.DuplicatePaneAuto",
      "keys": "alt+shift+d"
    },
    {
      "id": "Terminal.MoveFocusDown",
      "keys": "ctrl+shift+j"
    },
    {
      "id": "Terminal.DuplicatePaneRight",
      "keys": "ctrl+shift+\\"
    },
    {
      "id": "User.closePane",
      "keys": "ctrl+shift+x"
    },
    {
      "id": null,
      "keys": "alt+shift+minus"
    },
    {
      "id": null,
      "keys": "enter"
    },
    {
      "id": null,
      "keys": "alt+shift+plus"
    },
    {
      "id": null,
      "keys": "alt+down"
    },
    {
      "id": "Terminal.MoveFocusLeft",
      "keys": "ctrl+shift+h"
    },
    {
      "id": null,
      "keys": "alt+left"
    },
    {
      "id": "Terminal.MoveFocusRight",
      "keys": "ctrl+shift+l"
    },
    {
      "id": null,
      "keys": "alt+right"
    },
    {
      "id": "Terminal.MoveFocusUp",
      "keys": "ctrl+shift+k"
    },
    {
      "id": null,
      "keys": "alt+up"
    },
    {
      "id": "Terminal.ResizePaneDown",
      "keys": "ctrl+shift+down"
    },
    {
      "id": null,
      "keys": "alt+shift+down"
    },
    {
      "id": "Terminal.ResizePaneLeft",
      "keys": "ctrl+shift+left"
    },
    {
      "id": null,
      "keys": "alt+shift+left"
    },
    {
      "id": "Terminal.ResizePaneRight",
      "keys": "ctrl+shift+right"
    },
    {
      "id": null,
      "keys": "alt+shift+right"
    },
    {
      "id": "Terminal.ResizePaneUp",
      "keys": "ctrl+shift+up"
    },
    {
      "id": null,
      "keys": "alt+shift+up"
    }
  ],
  "newTabMenu": [
    {
      "type": "remainingProfiles"
    }
  ],
