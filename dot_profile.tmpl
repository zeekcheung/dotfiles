# Functions {{{

dus() { du -h "${1:-.}" --max-depth=1 | sort -h; }

# Fuzzy find a file and open it with vi
vf() {
  local target
  target="$(pwd)/$1"
  if [ -f "$target" ]; then
    vi "$target"
  elif [ -d "$target" ]; then
    pushd "$target" || exit
    local file
    file="$(fzf)"
    if [ -n "$file" ]; then
      vi "$file"
    fi
    popd || exit
  fi
}

# Fuzzy find a dotfile and open it with vi
dot() {
  pushd "$DOT_HOME" || exit
  vf "$1"
  popd || exit
}

# Fuzzy find a note file and open it with vi
note() {
  if [ -n "$1" ]; then
    vi "$NOTE_HOME/$1"
  else
    pushd "$NOTE_HOME" || exit
    vf "$1"
    popd || exit
  fi
}

