// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)

{
	// --- UI ---
	"theme": {
		"mode": "system",
		"light": "One Light",
		"dark": "One Dark"
	},
	"icon_theme": {
		"mode": "system",
		"light": "Material Icon Theme",
		"dark": "Material Icon Theme"
	},
	"ui_font_family": ".SystemUIFont",
	"ui_font_size": 20,
	"agent_buffer_font_size": 16,
	"agent_ui_font_size": 16,
	"buffer_font_family": "Maple Mono NF",
	"buffer_font_size": 20,
	"buffer_font_features": {
		"calt": true
	},
	"text_rendering_mode": "platform_default",
	"soft_wrap": "none",
	"preferred_line_length": 120,
	"colorize_brackets": true,
	"relative_line_numbers": "enabled",
	"gutter": {
		"min_line_number_digits": 2
	},
	"document_folding_ranges": "on",
	"indent_guides": {
		"background_coloring": "disabled",
		"coloring": "fixed"
	},
	"sticky_scroll": {
		"enabled": true
	},
	"semantic_tokens": "combined",
	"diagnostics": {
		"button": true,
		"inline": {
			"enabled": true
		}
	},
	"inlay_hints": {
		"enabled": true
	},
	"diff_view_style": "unified",
	"minimap": {
		"show": "auto"
	},
	"title_bar": {
		"show_branch_status_icon": true,
		"show_menus": false,
		"show_branch_name": true,
		"show_project_items": true,
		"show_sign_in": true,
		"show_user_menu": true,
		"show_user_picture": true,
		"show_onboarding_banner": false
	},
	"tab_bar": {
		"show": true,
		"show_nav_history_buttons": false
	},
	"tabs": {
		"file_icons": true,
		"git_status": false
	},
	"toolbar": {
		"breadcrumbs": false,
		"code_actions": true,
		"agent_review": true,
		"selections_menu": true,
		"quick_actions": false
	},
	"status_bar": {
		"active_language_button": true,
		"active_encoding_button": "enabled",
		"cursor_position_button": true,
		"line_endings_button": true
	},
	"preview_tabs": {
		"enable_keep_preview_on_code_navigation": true,
		"enable_preview_from_file_finder": true
	},
	"project_panel": {
		"dock": "left",
		"button": true,
		"entry_spacing": "comfortable",
		"auto_fold_dirs": false,
		"hide_root": false,
		"bold_folder_labels": false
	},
	"git_panel": {
		"dock": "left",
		"tree_view": true,
		"file_icons": true
	},
	"search": {
		"button": true
	},
	"debugger": {
		"button": true
	},
	"collaboration_panel": {
		"button": false
	},
	"outline_panel": {
		"dock": "right"
	},
	"terminal": {
		"shell": {
			"program": "nu"
		},
		"working_directory": "current_project_directory",
		"blinking": "on",
		"copy_on_select": true,
		"line_height": "standard",
		"toolbar": {
			"breadcrumbs": false
		},
		"font_features": {
			"calt": true
		}
	},
	"which_key": {
		"enabled": true,
		"delay_ms": 200
	},

	// --- Coding ---
	"vim_mode": true,
	"vim": {
		"use_smartcase_find": true,
		"use_system_clipboard": "always"
	},
	"tab_size": 2,
	"use_smartcase_search": true,

	// --- Languages & LSP ---
	"languages": {
		"Lua": {
			"format_on_save": "on",
			"formatter": {
				"external": {
					"command": "stylua",
					"arguments": [
						"--syntax=Lua54",
						"--respect-ignores",
						"--stdin-filepath",
						"{buffer_path}",
						"-"
					]
				}
			}
		},
		"Python": {
			"tab_size": 4,
			"language_servers": ["ty", "ruff"]
		},
		"TypeScript": {
			"language_servers": ["tsgo", "biome"],
			"formatter": { "language_server": { "name": "biome" } },
			"code_actions_on_format": {
				"source.fixAll.biome": true,
				"source.organizeImports.biome": true
			}
		},
		"TSX": {
			"language_servers": ["tsgo", "biome"],
			"formatter": { "language_server": { "name": "biome" } },
			"code_actions_on_format": {
				"source.fixAll.biome": true,
				"source.organizeImports.biome": true
			}
		},
		"JavaScript": {
			"language_servers": ["tsgo", "biome"],
			"formatter": { "language_server": { "name": "biome" } },
			"code_actions_on_format": {
				"source.fixAll.biome": true,
				"source.organizeImports.biome": true
			}
		},
		// "JSX": { "formatter": { "language_server": { "name": "biome" } } },
		// "Vue.js": { "formatter": { "language_server": { "name": "biome" } } },
		// "Astro": { "formatter": { "language_server": { "name": "biome" } } },
		// "Svelte": { "formatter": { "language_server": { "name": "biome" } } },
		"CSS": { "formatter": { "language_server": { "name": "biome" } } },
		"HTML": { "formatter": { "language_server": { "name": "biome" } } },
		"JSON": { "formatter": { "language_server": { "name": "biome" } } },
		"JSONC": { "formatter": { "language_server": { "name": "biome" } } },
		"YAML": { "prettier": { "allowed": true } },
		"Nu": { "formatter": { "external": { "command": "nufmt" } } },
		"Markdown": {
			// "prettier": { "allowed": true },
			"format_on_save": "on",
			"use_on_type_format": true,
			"remove_trailing_whitespace_on_save": true
		}
	},
	"lsp": {
		"biome": {
			"settings": {
				"require_config_file": false
			}
		},
		"powershell-es": {
			"settings": {
				"powershell": {
					// FIX: Cursor and view jumps to end of file on format
					// https://github.com/zed-industries/zed/issues/29120
					"codeFormatting": {
						"preset": "Custom",
						// "pipelineIndentationStyle": "NoIndentation",
						"addWhitespaceAroundPipe": true,
						"trimWhitespaceAroundPipe": true,
						"whitespaceAfterSeparator": true,
						"whitespaceAroundOperator": true,
						"whitespaceBeforeOpenBrace": true,
						"whitespaceBeforeOpenParen": true,
						"whitespaceBetweenParameters": false,
						"whitespaceInsideBrace": true,

						"ignoreOneLineBlock": false,
						"openBraceOnSameLine": true,
						"newLineAfterOpenBrace": true,
						"newLineAfterCloseBrace": true,
						"avoidSemicolonsAsLineTerminators": false,

						"alignPropertyValuePairs": false,
						"autoCorrectAliases": false,
						"useCorrectCasing": true,
						"useConstantStrings": false
					}
				}
			}
		}
	},
	"file_types": {
		"JSONC": [
			"*.cjson",
			".prettierrc",
			"keymap.json",
			"settings.json",
			"appsettings.json",
			"appsettings.*.json"
		],
		"Shell Script": [
			".bashenv",
			".tmux.conf",
			"**/.local/bin/*",
			"dot_bashrc",
			"dot_bash_profile",
			"dot_profile"
		],
		"PowerShell": ["*.ps1", "*.psd1", "*.psm1"],
		"ini": [".shellcheckrc", ".sqlfluff", ".desktop", "dunstrc"],
		"HTML": ["*.hbs", "*.html", "*.handlebars", "*.mustache"],
		"Git Config": ["dot_gitconfig"]
	},

	// --- System & Extensions ---
	"session": {
		"trust_all_worktrees": true
	},
	"telemetry": {
		"diagnostics": false,
		"metrics": false
	},
	"calls": {
		"mute_on_join": true
	},
	"auto_update": true,
	"auto_install_extensions": {
		"material-icon-theme": true,
		"comment": true,
		"tsgo": true,
		"biome": true,
		"lua": true,
		"nu": true,
		"markdown-oxide": true,
		"rumdl": true,
		"ini": true,
		"xml": true,
		"toml": true,
		"tombi": true,
		"log": true,
		"git-firefly": true,
		"editorconfig": true
	},

	// --- AI ---
	"edit_predictions": {
		"mode": "subtle",
		"provider": "zed"
	},
	"agent": {
		"sidebar_side": "right",
		"dock": "right",
		"default_profile": "minimal",
		"favorite_models": [],
		"model_parameters": [],
		"enable_feedback": false
	}
}
